generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // Mudamos de sqlite para postgresql
}

// --- MODELS (Nossas Tabelas) ---

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String   
  role      Role     @default(MEMBER) // Voltamos a usar o enum
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InviteCode {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())
}

enum Role {
  MEMBER
  ADMIN
}